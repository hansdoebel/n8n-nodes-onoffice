{
	"name": "n8n-nodes-onoffice",
	"version": "0.3.2",
	"description": "OnOffice custom node for n8n",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"n8n-node",
		"onOffice",
		"onoffice-api",
		"real-estate",
		"crm",
		"workflow-automation",
		"api-integration",
		"address-management",
		"estate-management"
	],
	"license": "MIT",
	"homepage": "https://github.com/hansdoebel/n8n-nodes-onoffice#readme",
	"author": {
		"name": "Hans Doebel",
		"email": "hansdev@mailbox.org"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/hansdoebel/n8n-nodes-onoffice.git"
	},
	"bugs": {
		"url": "https://github.com/hansdoebel/n8n-nodes-onoffice/issues"
	},
	"engines": {
		"node": ">=18.10"
	},
	"main": "index.js",
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"test": "bun test",
		"test:watch": "bun test --watch",
		"test:coverage": "bun test --coverage"
	},
	"files": [
		"dist"
	],
	"funding": {
		"type": "buymeacoffee",
		"url": "https://buymeacoffee.com/hansdoebel"
	},
	"n8n": {
		"n8nNodesApiVersion": 1,
		"credentials": [
			"dist/credentials/OnOfficeApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/OnOffice/OnOffice.node.js",
			"dist/nodes/OnOffice/OnOfficeTrigger.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "^0.23.1",
		"@types/bun": "^1.1.0",
		"@types/node": "^25.3.2",
		"eslint": "^8.57.1",
		"prettier": "^3.7.4",
		"typescript": "^5.9.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	},
	"patchedDependencies": {
		"@n8n/node-cli@0.23.1": "patches/@n8n%2Fnode-cli@0.23.1.patch"
	}
}
